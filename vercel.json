{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "swagger.yaml",
          "public/**",
          "admin_pages/**",
          "participant_pages/**"
        ]
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/api-docs", "destination": "/api/index.ts" },
    { "source": "/admin_pages/(.*)", "destination": "/api/index.ts" },
    { "source": "/participant_pages/(.*)", "destination": "/api/index.ts" },
    { "source": "/public/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/api/index.ts" }
  ]
}
