{
    "version": 2,
    "builds": [
        {
            "src": "src/index.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "prisma/**",
                    "node_modules/.prisma/client/**",
                    "swagger.yaml"
                ]
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "src/index.ts"
        },
        {
            "source": "/api-docs(.*)",
            "destination": "src/index.ts"
        },
        {
            "source": "/dashboard",
            "destination": "/Dashboard.html"
        }
    ]
}