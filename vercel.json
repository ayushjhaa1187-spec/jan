{
    "version": 2,
    "builds": [
        {
            "src": "src/index.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "public/**",
                    "admin_pages/**",
                    "swagger.yaml",
                    "participant_pages/**",
                    "prisma/schema.prisma",
                    "node_modules/.prisma/client/**",
                    "node_modules/@prisma/client/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/src/index.ts"
        },
        {
            "src": "/api-docs/(.*)",
            "dest": "/src/index.ts"
        },
        {
            "src": "/dashboard",
            "dest": "/src/index.ts"
        },
        {
            "src": "/scanner",
            "dest": "/src/index.ts"
        },
        {
            "src": "/events",
            "dest": "/src/index.ts"
        },
        {
            "src": "/attendees",
            "dest": "/src/index.ts"
        },
        {
            "src": "/analytics",
            "dest": "/src/index.ts"
        },
        {
            "src": "/settings",
            "dest": "/src/index.ts"
        },
        {
            "src": "/profile",
            "dest": "/src/index.ts"
        },
        {
            "src": "/privacy",
            "dest": "/src/index.ts"
        },
        {
            "src": "/terms",
            "dest": "/src/index.ts"
        },
        {
            "src": "/status",
            "dest": "/src/index.ts"
        },
        {
            "src": "/participant",
            "dest": "/src/index.ts"
        },
        {
            "src": "/admin",
            "dest": "/src/index.ts"
        },
        {
            "src": "/(.*)",
            "dest": "/src/index.ts"
        }
    ]
}