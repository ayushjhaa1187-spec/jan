{
    "version": 2,
    "functions": {
        "api/index.ts": {
            "includeFiles": "prisma/**,node_modules/.prisma/client/**,swagger.yaml"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/api-docs(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/dashboard",
            "destination": "/Dashboard.html"
        },
        {
            "source": "/",
            "destination": "/index.html"
        }
    ]
}