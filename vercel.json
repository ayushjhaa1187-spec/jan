{
    "version": 2,
    "builds": [
        {
            "src": "src/index.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/src/index.ts"
        },
        {
            "src": "/api-docs/(.*)",
            "dest": "/src/index.ts"
        },
        {
            "src": "/dashboard",
            "dest": "/src/index.ts"
        },
        {
            "src": "/scanner",
            "dest": "/src/index.ts"
        },
        {
            "src": "/events",
            "dest": "/src/index.ts"
        },
        {
            "src": "/attendees",
            "dest": "/src/index.ts"
        },
        {
            "src": "/analytics",
            "dest": "/src/index.ts"
        },
        {
            "src": "/settings",
            "dest": "/src/index.ts"
        },
        {
            "src": "/(.*)",
            "dest": "/src/index.ts"
        }
    ]
}
